{
  "name": "homebridge-haier-evo",
  "version": "2.0.3",
  "description": "Homebridge plugin for Haier Evo devices (air conditioners, refrigerators, etc.)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns=unit",
    "test:prepublish": "npm run build && npm run lint && npm run test:unit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test:standalone": "node run-tests.cjs",
    "test:standalone:api": "node run-tests.cjs --api",
    "test:standalone:devices": "node run-tests.cjs --devices",
    "test:standalone:ac": "node run-tests.cjs --ac-control",
    "test:standalone:all": "node run-tests.cjs --all",
    "test:rate-limiting": "node test-rate-limiting.cjs",
    "test:ac-control": "node test-ac-control.cjs",
    "release": "scripts/publish.sh",
    "release:patch": "scripts/publish.sh --patch",
    "release:minor": "scripts/publish.sh --minor",
    "release:major": "scripts/publish.sh --major"
  },
  "keywords": [
    "homebridge-plugin",
    "haier",
    "evo",
    "air-conditioner",
    "climate",
    "refrigerator",
    "smart-home"
  ],
  "author": "Haier Evo Team",
  "contributors": [
    "Adapted from and7ey/haier_evo"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "homebridge": ">=2.0.0"
  },
  "files": [
    "dist/",
    "config.schema.json",
    "LICENSE"
  ],
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "uuid": "^14.0.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "homebridge": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@typescript-eslint/utils": "^8.62.0",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "homebridge": "^2.0.0",
    "jest": "^30.0.0",
    "jiti": "^2.7.0",
    "mock-socket": "^9.3.0",
    "nock": "^13.3.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.0"
  },
  "overrides": {
    "js-yaml": ">=4.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kulikovav/homebridge-haier-evo.git"
  },
  "bugs": {
    "url": "https://github.com/kulikovav/homebridge-haier-evo/issues"
  },
  "homepage": "https://github.com/kulikovav/homebridge-haier-evo#readme"
}
